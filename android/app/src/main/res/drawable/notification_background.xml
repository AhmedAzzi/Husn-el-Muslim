<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Gradient background with app's primary color -->
    <gradient
        android:angle="135"
        android:startColor="#FF693B42"
        android:centerColor="#FF7A4750"
        android:endColor="#FF8B535E"
        android:type="linear" />
    
    <!-- Rounded corners -->
    <corners android:radius="8dp" />
    
    <!-- Optional border/stroke -->
    <stroke
        android:width="1dp"
        android:color="#90FFFFFF" />
        
</shape>
